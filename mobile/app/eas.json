{
  "cli": {
    "version": ">= 14.0.0",
    "appVersionSource": "local"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_API_URL": "http://localhost:8094/api/v1",
        "EXPO_PUBLIC_APP_NAME": "GoldMoodAstro",
        "EXPO_PUBLIC_PUBLIC_URL": "http://localhost:3095",
        "EXPO_PUBLIC_SUPPORT_EMAIL": "destek@goldmoodastro.com"
      }
    },
    "preview": {
      "distribution": "internal",
      "ios": { "simulator": false },
      "android": { "buildType": "apk" },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://goldmoodastro.com/api/v1",
        "EXPO_PUBLIC_APP_NAME": "GoldMoodAstro",
        "EXPO_PUBLIC_PUBLIC_URL": "https://goldmoodastro.com",
        "EXPO_PUBLIC_SUPPORT_EMAIL": "destek@goldmoodastro.com"
      }
    },
    "production": {
      "autoIncrement": true,
      "env": {
        "EXPO_PUBLIC_API_URL": "https://goldmoodastro.com/api/v1",
        "EXPO_PUBLIC_APP_NAME": "GoldMoodAstro",
        "EXPO_PUBLIC_PUBLIC_URL": "https://goldmoodastro.com",
        "EXPO_PUBLIC_SUPPORT_EMAIL": "destek@goldmoodastro.com"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
