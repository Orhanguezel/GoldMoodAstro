{
  "expo": {
    "name": "GoldMoodAstro",
    "slug": "goldmoodastro",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "goldmoodastro",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#2A2620"
    },
    "ios": {
      "bundleIdentifier": "com.goldmoodastro.app",
      "buildNumber": "1",
      "supportsTablet": false,
      "usesAppleSignIn": true,
      "googleServicesFile": "./GoogleService-Info.plist",
      "associatedDomains": [
        "applinks:goldmoodastro.com",
        "applinks:www.goldmoodastro.com"
      ],
      "infoPlist": {
        "NSMicrophoneUsageDescription": "Danışmanınızla sesli görüşme yapabilmek için mikrofon erişimi gereklidir.",
        "NSCameraUsageDescription": "Profil fotoğrafı yüklemek için kamera erişimi gereklidir.",
        "NSPhotoLibraryUsageDescription": "Profil fotoğrafı ve kahve falı görsellerinizi seçebilmek için fotoğraf arşivi erişimi gereklidir.",
        "NSPhotoLibraryAddUsageDescription": "Seçtiğiniz görselleri işleyebilmek ve gerektiğinde arşivinize kaydedebilmek için fotoğraf arşivi izni gereklidir.",
        "UIBackgroundModes": [
          "audio"
        ]
      }
    },
    "android": {
      "package": "com.goldmoodastro.app",
      "versionCode": 1,
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#C9A961"
      },
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.CAMERA",
        "android.permission.POST_NOTIFICATIONS"
      ],
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "goldmoodastro.com"
            },
            {
              "scheme": "https",
              "host": "www.goldmoodastro.com"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/favicon.png"
    },
    "privacyManifests": {
      "NSPrivacyTracking": false,
      "NSPrivacyTrackingDomains": [],
      "NSPrivacyAccessedAPITypes": [
        {
          "NSPrivacyAccessedAPIType": "NSPrivacyAccessedAPICategoryUserDefaults",
