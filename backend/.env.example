NODE_ENV=development
PORT=8094
APP_NAME=Platform

# ─── Database ──────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=app

# ─── Auth ──────────────────────────────────────────────────
JWT_SECRET=change-me-in-production
COOKIE_SECRET=change-me-in-production

# ─── Storage ───────────────────────────────────────────────
STORAGE_DRIVER=local
# local driver paths
LOCAL_STORAGE_ROOT=/var/www/app/uploads
LOCAL_STORAGE_BASE_URL=/uploads
# cloudinary (STORAGE_DRIVER=cloudinary)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=app
CLOUDINARY_UPLOAD_PRESET=
CLOUDINARY_UNSIGNED_PRESET=
CLOUDINARY_BASE_PUBLIC=

# ─── Mail / SMTP ───────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=465
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM=

# ─── Google OAuth ──────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── Facebook OAuth ────────────────────────────────────────
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=

# ─── Apple Sign In ─────────────────────────────────────────
# Web (Service ID — developer.apple.com → Identifiers → Services IDs):
#   örn. com.goldmoodastro.web
# Mobile (Bundle ID — iOS app identifier):
#   örn. com.goldmoodastro.mobile
# İkisi farklıysa virgülle ayırarak yaz:
#   APPLE_CLIENT_ID=com.goldmoodastro.web,com.goldmoodastro.mobile
APPLE_CLIENT_ID=

# ─── LiveKit (Sesli/Görüntülü Görüşme — Agora yerine) ──────
# Cloud: https://cloud.livekit.io  → Project URL'den WSS al
LIVEKIT_URL=wss://goldmoodastro-j03iq312.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# ─── IAP (Apple / Google) ─────────────────────────────────
IAP_APPLE_BUNDLE_ID=
IAP_APPLE_SHARED_SECRET=
IAP_APPLE_USE_SANDBOX=false
IAP_GOOGLE_PACKAGE_NAME=
IAP_GOOGLE_ACCESS_TOKEN=
IAP_GOOGLE_SERVICE_ACCOUNT_JSON=

# ─── Firebase FCM (Push Bildirim) ──────────────────────────
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# ─── Iyzipay ───────────────────────────────────────────────
IYZIPAY_API_KEY=
IYZIPAY_SECRET_KEY=
IYZIPAY_BASE_URL=https://sandbox-api.iyzipay.com

# ─── AI yorum üretimi (FAZ 9 + FAZ 19 + FAZ 20-25) ─────────
# Claude (yorum) — Anthropic dashboard → API Keys
ANTHROPIC_API_KEY=
# OpenAI (fallback / vision)
OPENAI_API_KEY=
OPENAI_API_BASE=https://api.openai.com/v1
# Groq — hızlı + ucuz ($0.003-0.008/rapor) — https://console.groq.com → API Keys
# Model önerisi: meta-llama/llama-4-scout-17b-16e-instruct (vision destekli)
# Veya: llama-3.3-70b-versatile (text-only, ücretsiz tier)
GROQ_API_KEY=
GROQ_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
GROQ_API_BASE=https://api.groq.com/openai/v1
# Embedding (anti-copy-paste, daily readings)
EMBEDDING_PROVIDER=openai
EMBEDDING_API_KEY=

# ─── Geocode (FAZ 8 — doğum yeri lat/lng) ──────────────────
GEOCODE_PROVIDER=nominatim
GEOCODE_API_KEY=

# ─── Feature flags ─────────────────────────────────────────
FEATURE_VIDEO_CALL=false
FEATURE_BIRTH_CHART=true
FEATURE_DAILY_READING=true

# ─── CORS / URLs ───────────────────────────────────────────
# Mobil uygulama için FRONTEND_URL = www domaininin ta kendisi.
# Iyzipay callback bu URL'e yönlendirir; WebView URL değişimini izler.
# Prod: https://www.goldmoodastro.com  Dev: http://localhost:8094
FRONTEND_URL=https://www.goldmoodastro.com
CORS_ORIGIN=https://www.goldmoodastro.com,https://admin.goldmoodastro.com
PUBLIC_URL=http://localhost:8094
BACKEND_URL=http://localhost:8094

# ─── Seeder ────────────────────────────────────────────────
# Override admin credentials during db:seed
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=admin123
# ALLOW_DROP=true  # gerekirse prod fresh seed için

# ─── Audit ─────────────────────────────────────────────────
AUDIT_RETENTION_DAYS=90
AUDIT_RETENTION_CLEANUP_MINUTES=360
