{
  "name": "goldmoodastro-backend",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "bun --hot src/index.ts",
    "build": "bun x tsc -p tsconfig.json && bun x tsc-alias -p tsconfig.json",
    "start": "node --experimental-specifier-resolution=node dist/index.js",
    "start:bun": "bun dist/index.js",
    "typecheck": "bun x tsc --noEmit",
    "test": "bun test",
    "db:seed": "bun src/db/index.ts",
    "db:seed:nodrop": "bun src/db/index.ts --no-drop",
    "db:seed:only": "bun src/db/index.ts"
  },
  "dependencies": {
    "@fastify/cookie": "^11",
    "@fastify/cors": "^11",
    "@fastify/jwt": "^10",
    "@fastify/multipart": "^9",
    "@fastify/mysql": "^5.0.2",
    "@fastify/static": "^8.3.0",
    "@fastify/swagger": "^9",
    "@fastify/swagger-ui": "^5",
    "@goldmood/shared-backend": "workspace:*",
    "argon2": "^0.44.0",
    "bcryptjs": "^3.0.2",
    "cloudinary": "^2.8.0",
    "dotenv": "^16.6.1",
    "drizzle-orm": "^0.44.6",
    "fastify": "^5",
    "fastify-plugin": "^5.1.0",
    "firebase-admin": "^13.6.0",
    "geoip-lite": "^1.4.10",
    "google-auth-library": "^10.4.1",
    "iyzipay": "^2.0.65",
    "livekit-server-sdk": "^2.15.1",
    "mysql2": "^3.15.3",
    "nodemailer": "^7.0.11",
    "openai": "^6.34.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "20",
    "@types/nodemailer": "^7.0.4",
    "bun-types": "^1.3.1",
    "tsc-alias": "^1.8.16",
    "tsx": "^4.20.6",
    "typescript": "5"
  }
}
